# Database
DATABASE_URL="mysql://kiki:kiki_dev@localhost:3306/kiki_studio"

# Auth.js v5
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Admin allowlist (comma-separated emails permitted to sign in to /admin)
ADMIN_EMAILS=""

# Signed action links (confirm/reject from email)
ACTION_TOKEN_SECRET=""

# Resend (transactional email)
RESEND_API_KEY=""
EMAIL_FROM="Kiki Studio <bookings@yourdomain.com>"

# Email transport: "resend" (default) or "file" for local testing + CI
EMAIL_TRANSPORT="resend"

# Cloudflare Turnstile
# Use these Cloudflare-provided test keys for local dev and e2e — they always pass validation.
# Replace with real keys from https://dash.cloudflare.com before deploying.
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Public site URL (used in emails + canonical links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Phase 1 booking notification recipient (distinct from ADMIN_EMAILS allowlist)
ADMIN_NOTIFY_EMAIL=""
